OPENAI_API_KEY=your_openai_api_key
LLM_API_KEY=${OPENAI_API_KEY}
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-5.4-mini
LLM_REASONING_EFFORT=low

GRAPH_BACKEND=graphiti
GRAPHITI_DRIVER=falkordb
GRAPHITI_RERANKER_MODEL=gpt-4o-mini
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_USERNAME=
FALKORDB_PASSWORD=

GRAPHITI_TELEMETRY_ENABLED=false
SEMAPHORE_LIMIT=3

FLASK_DEBUG=True

# Optional Neo4j backend. Set GRAPHITI_DRIVER=neo4j to use these.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Optional acceleration LLM config. Remove these if unused.
LLM_BOOST_API_KEY=
LLM_BOOST_BASE_URL=
LLM_BOOST_MODEL_NAME=
